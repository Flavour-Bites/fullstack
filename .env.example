# =============================================================================
# Flavour Bites — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection URL (e.g. postgresql://user:password@hostname/dbname?sslmode=require)
DATABASE_URL=

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Public URL of the app (e.g. https://flavourbites.com)
APP_URL=

# Secret token set via Telegram's setWebhook secret_token parameter.
# Must contain only ASCII printable characters (no quotes, hashes, semicolons, backslashes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=

# Cloudinary image hosting (get from https://console.cloudinary.com/)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────────

# Gemini AI API key (for chatbot feature)
GEMINI_API_KEY=

# Telegram staff group chat ID (negative number)
TELEGRAM_STAFF_CHAT_ID=

# Cloudinary upload folder (default: flavour-bites)
# CLOUDINARY_UPLOAD_FOLDER=flavour-bites

# Server port (default: 3000)
# PORT=3000

# Redis URL for conversation state (falls back to in-memory store)
# REDIS_URL=redis://localhost:6379

# Vite dev bot username (for frontend dev)
# VITE_TELEGRAM_BOT_USERNAME=flavour_bites_bot
